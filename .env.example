# =============================================================================
# BanusNVR — Environment Configuration
# =============================================================================
# Copy this file to ".env" (cp .env.example .env) and fill in the values.
# OR run the web setup wizard:  docker compose --profile setup up -d
#                                then visit http://<your-host-ip>:8090
# =============================================================================

# -----------------------------------------------------------------------------
# Image registry & tag (controls which version is pulled)
# -----------------------------------------------------------------------------
# Use "latest" for the most recent stable, or pin to a release tag e.g. "v1.2.0"
BANUSNVR_REGISTRY=ghcr.io/banusphil-dotcom
BANUSNVR_TAG=latest

# -----------------------------------------------------------------------------
# Host paths (where data lives on YOUR machine)
# -----------------------------------------------------------------------------
# These are the only host paths the stack writes to. Use absolute paths.
# On Windows: use forward-slashes or double-backslashes, e.g. C:/BanusNVR/data
DATA_ROOT=./data
RECORDINGS_PATH=./data/recordings
SNAPSHOTS_PATH=./data/snapshots
MODELS_PATH=./data/models
HOT_STORAGE_PATH=./data/livenvr

# -----------------------------------------------------------------------------
# Web access — port the PWA + API are served on
# -----------------------------------------------------------------------------
WEB_HTTP_PORT=8080

# Frigate web UI port (debug; not required for the PWA)
FRIGATE_PORT=5000

# go2rtc (embedded in Frigate) — RTSP/WebRTC for live streams
GO2RTC_RTSP_PORT=8554
GO2RTC_WEBRTC_PORT=8555
GO2RTC_API_PORT=1984

# Setup wizard (only needed for first-time install)
SETUP_WIZARD_PORT=8090

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=banusnvr
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=banusnvr
DATABASE_URL=postgresql+asyncpg://banusnvr:CHANGE_ME_strong_password_here@db:5432/banusnvr

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_64_char_hex_secret_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# Push notifications (Web Push / VAPID)
# -----------------------------------------------------------------------------
# Generate with: docker run --rm node:20-alpine npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:admin@example.com

# -----------------------------------------------------------------------------
# Email notifications (optional — leave blank to disable)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=banusnvr@example.com
SMTP_TLS=true

# -----------------------------------------------------------------------------
# Retention (days). 0 = disable continuous recording, motion-only.
# -----------------------------------------------------------------------------
RETENTION_EVENTS_DAYS=30
RETENTION_CONTINUOUS_DAYS=0
RETENTION_SNAPSHOTS_DAYS=30

# -----------------------------------------------------------------------------
# Local LLM (Ollama) — for AI-generated event narratives
# -----------------------------------------------------------------------------
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_VISION_MODEL=

# -----------------------------------------------------------------------------
# Remote ML server (optional GPU offload — see docs/ML-SERVER.md)
# Leave blank to use only the embedded models inside banusnvr-api.
# -----------------------------------------------------------------------------
DEEP_ML_URL=

# -----------------------------------------------------------------------------
# Ring camera bridge (optional — only set if you have Ring cameras)
# -----------------------------------------------------------------------------
RING_RTSP_USER=ring
RING_RTSP_PASSWORD=CHANGE_ME_ring_rtsp_password

# -----------------------------------------------------------------------------
# Cloudflare Tunnel (optional — for secure public access without port-forwarding)
# Leave blank to disable. Get token from Cloudflare Zero Trust dashboard.
# -----------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=

# -----------------------------------------------------------------------------
# Hardware acceleration (advanced — leave defaults if unsure)
# -----------------------------------------------------------------------------
# Set to "true" if you have a Coral USB Edge TPU plugged in
CORAL_ENABLED=false

# Frigate detector — "openvino" for Intel iGPU, "cpu" if no iGPU,
# "tensorrt" for NVIDIA, "edgetpu" for Coral
FRIGATE_DETECTOR=openvino

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=Europe/London
